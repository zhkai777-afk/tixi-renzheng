        </mxCell>
        <mxCell id="catalog" value="&lt;b&gt;MATERIAL_CATALOG_ITEM&lt;br&gt;MSF11-20 材料清单项&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK material_id&lt;br&gt;document_code = MSF11-20&lt;br&gt;category 通用/一阶段/二阶段&lt;br&gt;material_name 材料名称&lt;br&gt;sort_order 排序&lt;br&gt;active 是否启用&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="980" y="170" width="240" height="150" as="geometry" />
        </mxCell>
        <mxCell id="requirement" value="&lt;b&gt;MATERIAL_REQUIREMENT_RULE&lt;br&gt;材料适用/必备规则&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK rule_id&lt;br&gt;FK material_id&lt;br&gt;FK audit_type_key&lt;br&gt;FK system_code&lt;br&gt;required 是否必备&lt;br&gt;requirement_symbol ★/●/◆/空&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="980" y="365" width="240" height="150" as="geometry" />
        </mxCell>
        <mxCell id="task-material" value="&lt;b&gt;ARCHIVE_TASK_MATERIAL&lt;br&gt;任务材料项实例&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK task_material_id&lt;br&gt;FK archive_task_id&lt;br&gt;FK material_id&lt;br&gt;material_status 缺失/已带入/有问题/已通过&lt;br&gt;required 当前项目是否必交&lt;br&gt;file_count 文件数&lt;br&gt;missing_reason 缺失原因&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#e6f7f1;strokeColor=#00a870;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="690" y="365" width="250" height="165" as="geometry" />
        </mxCell>
        <mxCell id="material-file" value="&lt;b&gt;MATERIAL_FILE 具体文件&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK file_id&lt;br&gt;FK task_material_id&lt;br&gt;file_name 具体文件名称&lt;br&gt;file_source 前序带入/上传/资料库/在线表单&lt;br&gt;storage_url 存储地址&lt;br&gt;uploaded_by 上传人&lt;br&gt;uploaded_at 上传时间&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="690" y="585" width="250" height="165" as="geometry" />
        </mxCell>
        <mxCell id="file-system" value="&lt;b&gt;MATERIAL_FILE_SYSTEM&lt;br&gt;文件覆盖体系&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK file_system_id&lt;br&gt;FK file_id&lt;br&gt;FK system_code&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="980" y="610" width="240" height="105" as="geometry" />
        </mxCell>
        <mxCell id="submission" value="&lt;b&gt;STAGE_SUBMISSION 提交记录&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK submission_id&lt;br&gt;FK archive_task_id&lt;br&gt;from_status 提交前状态&lt;br&gt;target_stage 初次评定/二次评定&lt;br&gt;FK submitter_id&lt;br&gt;submitted_at 提交时间&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="690" y="790" width="250" height="145" as="geometry" />
        </mxCell>

        <mxCell id="eval-task" value="&lt;b&gt;EVALUATION_TASK 评定任务&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK evaluation_task_id&lt;br&gt;FK archive_task_id&lt;br&gt;stage initial / second&lt;br&gt;evaluation_status 待指派/评审中/退回/通过&lt;br&gt;FK dispatcher_id 评定管理员&lt;br&gt;completed_at 完成时间&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f1edff;strokeColor=#7b4dfe;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1380" y="170" width="240" height="150" as="geometry" />
        </mxCell>
        <mxCell id="assignment" value="&lt;b&gt;EXPERT_ASSIGNMENT 专家指派&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK assignment_id&lt;br&gt;FK evaluation_task_id&lt;br&gt;FK expert_id&lt;br&gt;FK system_code 授权体系&lt;br&gt;assignment_status 指派状态&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1380" y="370" width="240" height="130" as="geometry" />
        </mxCell>
        <mxCell id="review-result" value="&lt;b&gt;EXPERT_REVIEW_RESULT&lt;br&gt;专家评审结果&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK review_result_id&lt;br&gt;FK assignment_id&lt;br&gt;conclusion 通过/有问题/需补充&lt;br&gt;review_note 评审意见&lt;br&gt;submitted_at 提交时间&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1380" y="545" width="240" height="130" as="geometry" />
        </mxCell>
        <mxCell id="issue" value="&lt;b&gt;REVIEW_ISSUE 评定问题&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK issue_id&lt;br&gt;FK evaluation_task_id&lt;br&gt;FK task_material_id 问题归属材料项&lt;br&gt;FK system_code 涉及体系&lt;br&gt;issue_type 问题类型&lt;br&gt;issue_desc 问题描述&lt;br&gt;issue_status 有效/已处理/关闭&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fff7ed;strokeColor=#ff7d00;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1380" y="720" width="240" height="165" as="geometry" />
        </mxCell>
        <mxCell id="return-record" value="&lt;b&gt;RETURN_RECORD 退回记录&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK return_id&lt;br&gt;FK evaluation_task_id&lt;br&gt;FK archive_task_id&lt;br&gt;return_stage 初次评定/二次评定&lt;br&gt;return_reason 退回原因&lt;br&gt;returned_by 退回人&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fff1f2;strokeColor=#e34d59;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1380" y="930" width="240" height="145" as="geometry" />
        </mxCell>
        <mxCell id="user" value="&lt;b&gt;USER_ACCOUNT 用户/角色&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK user_id&lt;br&gt;user_name 姓名&lt;br&gt;role_type 项目管理/初评管理员/二评管理员/专家&lt;br&gt;org_name 所属组织&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1660" y="370" width="160" height="145" as="geometry" />
        </mxCell>

        <mxCell id="note-main" value="&lt;b&gt;建模口径&lt;/b&gt;&lt;br&gt;1. MATERIAL_CATALOG_ITEM 是 MSF11-20 的 48 项权威材料清单，ARCHIVE_TASK_MATERIAL 是某个归档任务下的材料项实例。&lt;br&gt;2. MATERIAL_FILE 是材料项下的附件证据，不承载评定结论。&lt;br&gt;3. REVIEW_ISSUE 关联 ARCHIVE_TASK_MATERIAL，不直接关联 MATERIAL_FILE，符合“问题登记在材料清单项级别”的规则。&lt;br&gt;4. 二次评定退回后的再次提交，通过 STAGE_SUBMISSION.target_stage = 二次评定 表达。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=13;fontColor=#374151;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="1105" width="1700" height="90" as="geometry" />
        </mxCell>

