        <mxCell id="customer" value="&lt;b&gt;CUSTOMER 客户&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK customer_id&lt;br&gt;customer_name 客户名称&lt;br&gt;unified_social_credit_code 统一社会信用代码&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="90" y="170" width="210" height="105" as="geometry" />
        </mxCell>
        <mxCell id="project" value="&lt;b&gt;CERTIFICATION_PROJECT 认证项目&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK project_id&lt;br&gt;UK task_no 任务号&lt;br&gt;FK customer_id&lt;br&gt;FK audit_type_key&lt;br&gt;project_status 项目状态&lt;br&gt;completed_at 项目完结时间&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
