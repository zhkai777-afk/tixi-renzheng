        </mxCell>
        <mxCell id="system-dict" value="&lt;b&gt;SYSTEM_DICT 体系字典&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK system_code&lt;br&gt;Q 质量管理体系&lt;br&gt;E 环境管理体系&lt;br&gt;S 职业健康安全&lt;br&gt;F 食品安全体系&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
