        <mxCell id="e-catalog-rule" value="1:N" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#64748b;endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;fontSize=12;fontColor=#4b5563;" edge="1" parent="1" source="catalog" target="requirement"><mxGeometry relative="1" as="geometry" /></mxCell>
