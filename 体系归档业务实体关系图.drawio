        <mxCell id="archive-task" value="&lt;b&gt;ARCHIVE_TASK 归档任务&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PK archive_task_id&lt;br&gt;FK project_id&lt;br&gt;archive_status 草稿/待提交/初评/二评/已完结&lt;br&gt;required_item_count 必备项数&lt;br&gt;completed_item_count 已齐全项数&lt;br&gt;completeness_rate 完整率&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#e8f1ff;strokeColor=#0052d9;fontSize=13;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
